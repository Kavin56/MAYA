# Local dev: point at the RunPod backend via ngrok
# Copy this to .env.local (which is gitignored) to use
VITE_OPENWORK_URL=https://nondetonating-cecile-nongrounded.ngrok-free.dev

# OpenRouter API Key — used by the OWL backend for multi-agent orchestration
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
