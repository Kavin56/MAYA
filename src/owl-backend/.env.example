# ─────────────────────────────────────────────────────────────────
# MAYA OWL Backend — Environment Variables
# Copy to .env (gitignored). Never commit .env or real keys.
#   cp src/owl-backend/.env.example src/owl-backend/.env
# ─────────────────────────────────────────────────────────────────

# OpenRouter API Key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Ngrok (for runpod-start.sh)
NGROK_AUTHTOKEN=your-ngrok-token

# Frontend API base URL (optional; for reference / build)
VITE_API_URL=https://your-ngrok-domain.ngrok-free.dev/
