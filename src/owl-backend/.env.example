# ─────────────────────────────────────────────────────────────────
# MAYA OWL Backend — Environment Variables
# Copy to .env (gitignored). Never commit .env or real keys.
#   cp src/owl-backend/.env.example src/owl-backend/.env
# ─────────────────────────────────────────────────────────────────

# OpenRouter API Key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Cloudflare Tunnel (runpod-start.sh loads this file — set once, never commit .env)
# Get token: Zero Trust → Networks → Connectors → your tunnel → Install and run connectors
# Paste your token below; script reads it every run so you don't set it again per pod.
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-from-dashboard
CLOUDFLARE_PUBLIC_URL=https://maya.cfargotunnel.com
# Optional: set to 1 to install tunnel as system service (runs on boot). Else script runs tunnel in session.
# CLOUDFLARE_SERVICE_INSTALL=1

# Frontend API base URL (optional; same as CLOUDFLARE_PUBLIC_URL for RunPod)
VITE_API_URL=https://maya.cfargotunnel.com/
